.container {
  padding: 16px;
  padding-bottom: 80px;
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  min-height: 100vh;
}

.publish-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.publish-textarea {
  width: 100%;
  min-height: 120px;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 12px;
  font-size: 15px;
  line-height: 1.7;
  color: #f3f4f6;
}

.publish-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}

.mood-tags {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.mood-tag {
  padding: 6px 12px;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 999px;
  font-size: 12px;
  color: #d1d5db;
}

.mood-tag.active {
  background: #f59e0b;
  border-color: #f59e0b;
  color: #fff;
}

.publish-btn {
  padding: 8px 20px;
  background: #f59e0b;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 14px;
  font-weight: 600;
}

.posts-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.post-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.post-user { font-size: 14px; font-weight: 600; color: #fef3c7; }
.post-time { font-size: 12px; color: #9ca3af; }

.post-mood {
  display: inline-block;
  font-size: 11px;
  color: #fde68a;
  background: rgba(245, 158, 11, 0.15);
  padding: 2px 8px;
  border-radius: 999px;
  margin-bottom: 8px;
}

.post-content {
  display: block;
  font-size: 15px;
  line-height: 1.7;
  color: #d1d5db;
}

.post-footer {
  display: flex;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.post-action {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: #9ca3af;
}

.post-action.liked { color: #f87171; }

.empty {
  text-align: center;
  padding: 48px 20px;
  color: #9ca3af;
}

.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.4; }
.empty-text { font-size: 14px; }
