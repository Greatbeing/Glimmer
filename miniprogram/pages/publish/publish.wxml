<view class="container">
  <view class="publish-card">
    <textarea class="publish-textarea" placeholder="分享此刻的想法..." maxlength="{{maxChars}}" value="{{content}}" bindinput="onInput"></textarea>
    <view class="char-count {{charCount > maxChars * 0.9 ? 'warning' : ''}} {{charCount >= maxChars ? 'error' : ''}}">{{charCount}} / {{maxChars}}</view>
    <view class="publish-footer">
      <view class="mood-tags">
        <view class="mood-tag {{selectedMood === '' ? 'active' : ''}}" data-mood="" bindtap="selectMood">无</view>
        <view class="mood-tag {{selectedMood === '开心' ? 'active' : ''}}" data-mood="开心" bindtap="selectMood">开心</view>
        <view class="mood-tag {{selectedMood === '感悟' ? 'active' : ''}}" data-mood="感悟" bindtap="selectMood">感悟</view>
        <view class="mood-tag {{selectedMood === '思念' ? 'active' : ''}}" data-mood="思念" bindtap="selectMood">思念</view>
        <view class="mood-tag {{selectedMood === '宁静' ? 'active' : ''}}" data-mood="宁静" bindtap="selectMood">宁静</view>
      </view>
      <button class="publish-btn" bindtap="publish">发布</button>
    </view>
  </view>

  <view class="posts-list">
    <view class="post-card" wx:for="{{posts}}" wx:key="id">
      <view class="post-header">
        <text class="post-user">微光用户</text>
        <text class="post-time">{{item.timeText}}</text>
      </view>
      <text class="post-mood" wx:if="{{item.mood}}">{{item.mood}}</text>
      <text class="post-content">{{item.content}}</text>
      <view class="post-footer">
        <view class="post-action {{item.liked ? 'liked' : ''}}" data-id="{{item.id}}" bindtap="toggleLike">
          <text>♥</text>
          <text>{{item.likes}}</text>
        </view>
        <view class="post-action" data-id="{{item.id}}" bindtap="deletePost">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{posts.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无发布内容</text>
  </view>
</view>
