<view class="container">
  <!-- 未登录提示 -->
  <view class="login-hint" wx:if="{{!isLoggedIn}}">
    <text class="hint-icon">✦</text>
    <text class="hint-text">登录后查看其他用户的微光</text>
    <button class="hint-btn" bindtap="goToLogin">去登录</button>
  </view>

  <!-- 内容流 -->
  <view class="feed-list" wx:else>
    <view class="feed-card" wx:for="{{feed}}" wx:key="_id">
      <view class="feed-header">
        <image class="feed-avatar" src="{{item.avatarUrl}}" mode="aspectFill" wx:if="{{item.avatarUrl}}" />
        <view class="feed-avatar-placeholder" wx:else>☀</view>
        <view class="feed-user-info">
          <text class="feed-nickname">{{item.nickname}}</text>
          <text class="feed-time">{{item.timeText}}</text>
        </view>
      </view>

      <text class="feed-content">{{item.content}}</text>

      <view class="feed-quote-card" wx:if="{{item.quoteZh}}">
        <text class="feed-quote-text">"{{item.quoteZh}}"</text>
        <text class="feed-quote-source">——《{{item.quoteSource}}》</text>
      </view>

      <view class="feed-mood" wx:if="{{item.moodTag}}">
        <text>{{item.moodTag}}</text>
      </view>

      <view class="feed-footer">
        <view class="feed-action {{item.isLiked ? 'liked' : ''}}" data-id="{{item._id}}" data-index="{{index}}" bindtap="toggleLike">
          <text class="action-icon">♥</text>
          <text>{{item.likeCount || 0}}</text>
        </view>
        <view class="feed-action">
          <text class="action-icon">💬</text>
          <text>{{item.commentCount || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text wx:if="{{loading}}">加载中...</text>
      <button wx:else class="load-more-btn" bindtap="loadMore">加载更多</button>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{feed.length === 0 && !loading}}">
      <text class="empty-icon">✦</text>
      <text class="empty-text">暂无内容，快来发布第一条微光吧</text>
    </view>
  </view>
</view>
