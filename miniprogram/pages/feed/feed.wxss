.container {
  padding: 12px;
  padding-bottom: 88px;
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  min-height: 100vh;
}

/* 未登录提示 */
.login-hint {
  text-align: center;
  padding: 60px 20px;
}

.hint-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 16px;
  opacity: 0.5;
}

.hint-text {
  font-size: 14px;
  color: #9ca3af;
  display: block;
  margin-bottom: 20px;
}

.hint-btn {
  background: #f59e0b !important;
  border: none !important;
  border-radius: 10px !important;
  padding: 10px 30px !important;
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #fff !important;
}

/* 内容流 */
.feed-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.feed-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.feed-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.feed-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
}

.feed-avatar-placeholder {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #fff;
}

.feed-user-info {
  display: flex;
  flex-direction: column;
}

.feed-nickname {
  font-size: 14px;
  font-weight: 600;
  color: #fef3c7;
}

.feed-time {
  font-size: 12px;
  color: #9ca3af;
  margin-top: 2px;
}

.feed-content {
  font-size: 15px;
  line-height: 1.7;
  color: #d1d5db;
  display: block;
  margin-bottom: 12px;
}

.feed-quote-card {
  background: rgba(245, 158, 11, 0.1);
  border-left: 4rpx solid #f59e0b;
  padding: 12px;
  border-radius: 8px;
  margin-bottom: 12px;
}

.feed-quote-text {
  font-size: 14px;
  color: #fffbf7;
  display: block;
  margin-bottom: 6px;
}

.feed-quote-source {
  font-size: 12px;
  color: #9ca3af;
}

.feed-mood {
  display: inline-block;
  font-size: 12px;
  color: #fde68a;
  background: rgba(245, 158, 11, 0.15);
  padding: 4px 10px;
  border-radius: 999px;
  margin-bottom: 12px;
}

.feed-footer {
  display: flex;
  gap: 24px;
  padding-top: 12px;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.feed-action {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #9ca3af;
}

.feed-action.liked {
  color: #f87171;
}

.action-icon {
  font-size: 16px;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 16px;
  color: #9ca3af;
  font-size: 14px;
}

.load-more-btn {
  background: rgba(255, 255, 255, 0.05) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1) !important;
  border-radius: 10px !important;
  padding: 10px !important;
  font-size: 14px !important;
  color: #9ca3af !important;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60px 20px;
  color: #9ca3af;
}

.empty-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
  opacity: 0.4;
}

.empty-text {
  font-size: 14px;
}
