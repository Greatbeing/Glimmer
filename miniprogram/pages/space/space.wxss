.container {
  padding: 12px;
  padding-bottom: 88px;
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  min-height: 100vh;
}

/* ====== 登录页面 ====== */
.login-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.login-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 40px 30px;
  text-align: center;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
  width: 100%;
  max-width: 320px;
}

.login-icon {
  font-size: 64px;
  margin-bottom: 20px;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.05); }
}

.login-title {
  font-size: 22px;
  font-weight: 700;
  color: #fef3c7;
  display: block;
  margin-bottom: 10px;
}

.login-desc {
  font-size: 14px;
  color: #9ca3af;
  display: block;
  margin-bottom: 30px;
  line-height: 1.6;
}

.login-btn {
  background: linear-gradient(135deg, #f59e0b, #d97706) !important;
  border: none !important;
  border-radius: 12px !important;
  padding: 14px 30px !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  color: #fff !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 10px;
  box-shadow: 0 4px 15px rgba(245, 158, 11, 0.3) !important;
}

.login-btn-icon {
  font-size: 20px;
}

.login-hint {
  font-size: 12px;
  color: #6b7280;
  display: block;
  margin-top: 16px;
}

/* ====== Header ====== */
.space-header {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.space-avatar {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: #fff;
  box-shadow: 0 4px 12px rgba(245, 158, 11, 0.25);
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-info { display: flex; flex-direction: column; }
.space-name { font-size: 18px; font-weight: 700; color: #fef3c7; }
.space-desc { font-size: 12px; color: #9ca3af; margin-top: 4px; }

.header-actions {
  display: flex;
  gap: 8px;
  margin-left: auto;
}

.logout-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(239, 68, 68, 0.2);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #f87171;
}

.stats-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 32px;
  background: rgba(255,255,255,0.1);
}

.stat-value {
  display: block;
  font-size: 24px;
  font-weight: 800;
  color: #fbbf24;
}

.stat-label {
  font-size: 11px;
  color: #9ca3af;
  margin-top: 4px;
}

.checkin-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 20px;
  height: 20px;
  background: #f59e0b;
  border-radius: 50%;
  font-size: 14px;
  font-weight: bold;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 2s ease-in-out infinite;
}

/* ====== 徽章展示 ====== */
.badges-section {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.badges-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.badges-title {
  font-size: 14px;
  font-weight: 600;
  color: #fef3c7;
}

.badges-count {
  font-size: 12px;
  color: #9ca3af;
}

.badges-scroll {
  white-space: nowrap;
}

.badges-list {
  display: inline-flex;
  gap: 12px;
}

.badge-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 60px;
}

.badge-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(217, 119, 6, 0.1));
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-bottom: 6px;
}

.badge-name {
  font-size: 11px;
  color: #9ca3af;
  text-align: center;
}

/* ====== 邀请卡片 ====== */
.invite-card {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(217, 119, 6, 0.1));
  border: 1rpx solid rgba(245, 158, 11, 0.25);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.invite-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.invite-title {
  font-size: 16px;
  font-weight: 600;
  color: #fef3c7;
}

.invite-code {
  font-size: 18px;
  font-weight: 800;
  color: #fbbf24;
  letter-spacing: 2px;
  background: rgba(0, 0, 0, 0.2);
  padding: 6px 12px;
  border-radius: 8px;
}

.invite-code.empty {
  color: #6b7280;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: 0;
}

.invite-desc {
  font-size: 13px;
  color: #9ca3af;
  display: block;
  margin-bottom: 16px;
  line-height: 1.5;
}

.invite-actions {
  display: flex;
  gap: 10px;
}

.invite-btn {
  flex: 1;
  background: #f59e0b !important;
  border: none !important;
  border-radius: 10px !important;
  padding: 10px !important;
  font-size: 14px !important;
  font-weight: 600 !important;
  color: #fff !important;
}

.invite-btn.secondary {
  background: rgba(255, 255, 255, 0.1) !important;
  color: #d1d5db !important;
}

/* ====== Tabs ====== */
.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 4px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 8px;
  font-size: 13px;
  font-weight: 500;
  color: #9ca3af;
  border-radius: 8px;
}

.tab-btn.active {
  background: #f59e0b;
  color: #fff;
  box-shadow: 0 2px 8px rgba(245, 158, 11, 0.2);
}

.tab-content { min-height: 200px; }
.tab-panel { display: none; }
.tab-panel.active { display: flex; flex-direction: column; gap: 12px; }

.caught-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  position: relative;
  border-left: 6rpx solid #f59e0b;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.caught-text {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 15px;
  line-height: 1.7;
  color: #fffbf7;
  margin-bottom: 8px;
}

.caught-source {
  font-size: 12px;
  color: #9ca3af;
}

.caught-remove {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 24px;
  height: 24px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
  font-size: 12px;
  text-align: center;
  line-height: 24px;
  color: #9ca3af;
}

.post-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.post-user { font-size: 14px; font-weight: 600; color: #fef3c7; }
.post-time { font-size: 12px; color: #9ca3af; }

.post-mood {
  display: inline-block;
  font-size: 11px;
  color: #fde68a;
  background: rgba(245, 158, 11, 0.15);
  padding: 2px 8px;
  border-radius: 999px;
  margin-bottom: 8px;
}

.post-content {
  display: block;
  font-size: 15px;
  line-height: 1.7;
  color: #d1d5db;
}

.post-footer {
  display: flex;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.post-action {
  font-size: 13px;
  color: #9ca3af;
}

.empty {
  text-align: center;
  padding: 48px 20px;
  color: #9ca3af;
}

.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.4; }
.empty-text { font-size: 14px; }

/* Settings Icon */
.settings-icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

/* Settings Modal */
.settings-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.settings-mask.show {
  opacity: 1;
  visibility: visible;
}

.settings-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.95);
  width: 85%;
  max-width: 360px;
  background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 20px;
  padding: 28px;
  z-index: 101;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.settings-modal.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.settings-title {
  font-size: 18px;
  font-weight: 700;
  color: #fef3c7;
  margin-bottom: 16px;
}

.settings-group {
  margin-bottom: 16px;
}

.settings-label {
  font-size: 13px;
  color: #9ca3af;
  margin-bottom: 6px;
  display: block;
}

.settings-input {
  width: 100%;
  background: rgba(0,0,0,0.3);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 14px;
  color: #f3f4f6;
}

.settings-hint {
  font-size: 11px;
  color: #9ca3af;
  margin-top: 4px;
  display: block;
}

.settings-picker {
  width: 100%;
  background: rgba(0,0,0,0.3);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 14px;
  color: #f3f4f6;
}

.settings-quota {
  margin-top: 12px;
  padding: 10px;
  background: rgba(0,0,0,0.2);
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.settings-quota-label {
  font-size: 12px;
  color: #9ca3af;
}

.settings-quota-value {
  font-size: 14px;
  font-weight: 600;
  color: #fbbf24;
}

.settings-actions {
  display: flex;
  gap: 10px;
  margin-top: 20px;
}

.settings-btn {
  flex: 1;
  padding: 10px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 600;
  border: none;
}

.settings-btn.primary {
  background: #f59e0b;
  color: white;
}

.settings-btn.secondary {
  background: rgba(255,255,255,0.1);
  color: #d1d5db;
}
