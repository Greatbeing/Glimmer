.container {
  padding: 16px;
  padding-bottom: 80px;
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  min-height: 100vh;
}

.space-header {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.space-avatar {
  width: 56px;
  height: 56px;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: #fff;
  box-shadow: 0 4px 12px rgba(245, 158, 11, 0.25);
}

.user-info { display: flex; flex-direction: column; }
.space-name { font-size: 18px; font-weight: 700; color: #fef3c7; }
.space-desc { font-size: 12px; color: #9ca3af; margin-top: 4px; }

.stats-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 32px;
  background: rgba(255,255,255,0.1);
}

.stat-value {
  display: block;
  font-size: 24px;
  font-weight: 800;
  color: #fbbf24;
}

.stat-label {
  font-size: 11px;
  color: #9ca3af;
  margin-top: 4px;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 4px;
  margin-bottom: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.tab-btn {
  flex: 1;
  text-align: center;
  padding: 8px;
  font-size: 13px;
  font-weight: 500;
  color: #9ca3af;
  border-radius: 8px;
}

.tab-btn.active {
  background: #f59e0b;
  color: #fff;
  box-shadow: 0 2px 8px rgba(245, 158, 11, 0.2);
}

.tab-content { min-height: 200px; }
.tab-panel { display: none; }
.tab-panel.active { display: flex; flex-direction: column; gap: 12px; }

.caught-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  position: relative;
  border-left: 6rpx solid #f59e0b;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.caught-text {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 15px;
  line-height: 1.7;
  color: #fffbf7;
  margin-bottom: 8px;
}

.caught-source {
  font-size: 12px;
  color: #9ca3af;
}

.caught-remove {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 24px;
  height: 24px;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
  font-size: 12px;
  text-align: center;
  line-height: 24px;
  color: #9ca3af;
}

.post-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.post-user { font-size: 14px; font-weight: 600; color: #fef3c7; }
.post-time { font-size: 12px; color: #9ca3af; }

.post-mood {
  display: inline-block;
  font-size: 11px;
  color: #fde68a;
  background: rgba(245, 158, 11, 0.15);
  padding: 2px 8px;
  border-radius: 999px;
  margin-bottom: 8px;
}

.post-content {
  display: block;
  font-size: 15px;
  line-height: 1.7;
  color: #d1d5db;
}

.post-footer {
  display: flex;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.post-action {
  font-size: 13px;
  color: #9ca3af;
}

.empty {
  text-align: center;
  padding: 48px 20px;
  color: #9ca3af;
}

.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.4; }
.empty-text { font-size: 14px; }
