<view class="container">
  <!-- 未登录状态：显示登录按钮 -->
  <view class="login-section" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <view class="login-icon">☀</view>
      <text class="login-title">欢迎使用 Glimmer 微光</text>
      <text class="login-desc">登录后可同步数据、分享语录、邀请好友</text>
      <button class="login-btn" bindtap="handleLogin">
        <text class="login-btn-icon">✦</text>
        <text>微信授权登录</text>
      </button>
      <text class="login-hint">登录后享受完整功能</text>
    </view>
  </view>

  <!-- 已登录状态：显示用户信息 -->
  <view class="space-header" wx:else>
    <view class="space-avatar" wx:if="{{user.avatarUrl}}">
      <image class="avatar-img" src="{{user.avatarUrl}}" mode="aspectFill" />
    </view>
    <view class="space-avatar" wx:else>☀</view>
    <view class="user-info">
      <text class="space-name">{{user.nickname}}</text>
      <text class="space-desc">记录生活，捕捉微光</text>
    </view>
    <view class="header-actions">
      <view class="settings-icon" bindtap="showApiSettings">⚙</view>
    </view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-bar" wx:if="{{isLoggedIn}}">
    <view class="stat-item" bindtap="doCheckin">
      <text class="stat-value">{{checkinStreak}}</text>
      <text class="stat-label">连续打卡</text>
      <view class="checkin-badge" wx:if="{{!hasCheckedInToday}}">+</view>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{caughtCount}}</text>
      <text class="stat-label">捕捉</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{postCount}}</text>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{likeCount}}</text>
      <text class="stat-label">获赞</text>
    </view>
  </view>

  <!-- 徽章展示 -->
  <view class="badges-section" wx:if="{{isLoggedIn && badges.length > 0}}">
    <view class="badges-header">
      <text class="badges-title">我的徽章</text>
      <text class="badges-count">{{badges.length}}/{{totalBadges}}</text>
    </view>
    <scroll-view class="badges-scroll" scroll-x>
      <view class="badges-list">
        <view class="badge-item" wx:for="{{badges}}" wx:key="key">
          <view class="badge-icon">{{item.icon}}</view>
          <text class="badge-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 邀请卡片 -->
  <view class="invite-card" wx:if="{{isLoggedIn}}">
    <view class="invite-header">
      <text class="invite-title">邀请好友</text>
      <text class="invite-code">{{user.inviteCode}}</text>
    </view>
    <text class="invite-desc">分享邀请码，好友注册双方各得 50 次 LLM 额度</text>
    <view class="invite-actions">
      <button class="invite-btn" bindtap="shareInvite">分享邀请</button>
      <button class="invite-btn secondary" bindtap="copyInviteCode">复制邀请码</button>
    </view>
  </view>

  <!-- Tabs -->
  <view class="tabs" wx:if="{{isLoggedIn}}">
    <view class="tab-btn {{activeTab === 'caught' ? 'active' : ''}}" data-tab="caught" bindtap="switchTab">我的捕捉</view>
    <view class="tab-btn {{activeTab === 'posts' ? 'active' : ''}}" data-tab="posts" bindtap="switchTab">我的发布</view>
  </view>

  <view class="tab-content" wx:if="{{isLoggedIn}}">
    <!-- Caught Quotes -->
    <view class="tab-panel {{activeTab === 'caught' ? 'active' : ''}}">
      <view class="caught-card" wx:for="{{caught}}" wx:key="id" wx:if="{{caught.length > 0}}">
        <text class="caught-text">{{item.zh || item.content}}</text>
        <text class="caught-source">——《{{item.source}}》</text>
        <view class="caught-remove" data-id="{{item.id}}" bindtap="removeCaught">✕</view>
      </view>
      <view class="empty" wx:if="{{caught.length === 0}}">
        <text class="empty-icon">✦</text>
        <text class="empty-text">暂无捕捉</text>
      </view>
    </view>

    <!-- Posts -->
    <view class="tab-panel {{activeTab === 'posts' ? 'active' : ''}}">
      <view class="post-card" wx:for="{{posts}}" wx:key="id" wx:if="{{posts.length > 0}}">
        <view class="post-header">
          <text class="post-user">{{user.nickname}}</text>
          <text class="post-time">{{item.timeText}}</text>
        </view>
        <text class="post-mood" wx:if="{{item.mood}}">{{item.mood}}</text>
        <text class="post-content">{{item.content}}</text>
        <view class="post-footer">
          <view class="post-action {{item.liked ? 'liked' : ''}}" data-id="{{item.id}}" bindtap="toggleLike">
            <text>♥ {{item.likes}}</text>
          </view>
          <view class="post-action" data-id="{{item.id}}" bindtap="deletePost">
            <text>删除</text>
          </view>
        </view>
      </view>
      <view class="empty" wx:if="{{posts.length === 0}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">暂无发布</text>
      </view>
    </view>
  </view>

  <!-- API Settings Modal -->
  <view class="settings-mask {{showSettings ? 'show' : ''}}" bindtap="hideSettings"></view>
  <view class="settings-modal {{showSettings ? 'show' : ''}}">
    <view class="settings-title">⚙ API 设置</view>
    
    <view class="settings-group">
      <text class="settings-label">API Key</text>
      <input class="settings-input" type="text" password="{{!showKey}}" placeholder="请输入你的 API Key" value="{{apiKeyInput}}" bindinput="onApiKeyInput" />
      <text class="settings-hint">你的 API Key 仅存储在本地</text>
    </view>
    
    <view class="settings-group">
      <text class="settings-label">AI 模型</text>
      <picker mode="selector" range="{{modelOptions}}" value="{{modelIndex}}" bindchange="onModelChange">
        <view class="settings-picker">{{modelOptions[modelIndex]}} ▾</view>
      </picker>
    </view>
    
    <view class="settings-group">
      <text class="settings-label">API 地址</text>
      <input class="settings-input" type="text" placeholder="https://dashscope.aliyuncs.com/compatible-mode/v1" value="{{apiUrlInput}}" bindinput="onApiUrlInput" />
      <text class="settings-hint">OpenAI 兼容格式的 API 地址</text>
    </view>
    
    <view class="settings-quota">
      <text class="settings-quota-label">今日 LLM 调用</text>
      <text class="settings-quota-value">{{quotaUsed}} / {{quotaTotal}}</text>
    </view>
    
    <view class="settings-actions">
      <button class="settings-btn secondary" bindtap="hideSettings">取消</button>
      <button class="settings-btn primary" bindtap="saveApiConfig" loading="{{saving}}">保存并验证</button>
    </view>
  </view>
</view>
