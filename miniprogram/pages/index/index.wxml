<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="header-title">
      <text class="logo">Glimmer</text>
      <text class="slogan">每日微光，照亮心房</text>
    </view>
  <view class="header-right">
    <view class="header-music {{isPlaying ? 'active' : ''}}" bindtap="toggleMusic">🎵</view>
    <view class="header-bulb">
      <text class="header-bulb-icon">💡</text>
    </view>
    <view class="settings-btn" wx:if="{{showApiIcon}}" bindtap="goToSettings">⚙</view>
  </view>
  </view>

  <!-- Quote Card -->
  <view class="quote-card {{isLoading ? 'loading' : ''}}" 
        style="transform: translateY({{swipeOffset}}px); opacity: {{swipeOpacity}};"
        bindtouchstart="onTouchStart" bindtouchmove="onTouchMove" bindtouchend="onTouchEnd">
    <view class="quote-inner">
      <!-- Loading Overlay -->
      <view class="loading-overlay" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">{{loadingText}}</text>
      </view>

      <!-- Badge -->
      <view class="quote-badge">
        <text class="badge-icon">☀</text>
        <text class="badge-text">{{currentQuote.badge || '晨曦之光'}}</text>
        <view class="wave">
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
          <view class="wave-bar"></view>
        </view>
      </view>

      <!-- Content -->
      <text class="quote-zh">"{{currentQuote.zh}}"</text>
      <text class="quote-en" wx:if="{{currentQuote.en}}">{{currentQuote.en}}</text>
      <text class="quote-source">——《{{currentQuote.source}}》</text>
      <text class="quote-context" wx:if="{{currentQuote.context}}">{{currentQuote.context}}</text>
      <text class="quote-tag" wx:if="{{currentQuote.tag}}">
        <text>{{currentQuote.tag}}</text>
        <text wx:if="{{categoryText}}" class="quote-tag-cat"> · {{categoryText}}</text>
      </text>

      <!-- Actions -->
      <view class="quote-actions">
        <view class="actions-left">
          <view class="action-btn {{isLiked ? 'liked' : ''}}" bindtap="toggleLike">
            <text class="action-icon">♥</text>
            <text class="action-count">{{likeCount}}</text>
          </view>
          <view class="action-btn" bindtap="toggleComment">
            <text class="action-icon">💬</text>
            <text class="action-count">{{commentCount}}</text>
          </view>
          <view class="action-btn" bindtap="shareQuote">
            <text class="action-icon">↗</text>
            <text class="action-count">分享</text>
          </view>
        </view>
        <view class="capture-btn {{isCaught ? 'caught' : ''}}" bindtap="catchQuote">
          <text class="capture-icon">📷</text>
          <text>捕捉微光</text>
        </view>
      </view>
    </view>

    <!-- Comments Panel -->
    <view class="comments-panel" wx:if="{{showComments}}">
      <view class="comments-header">
        <text class="comments-title">评论 ({{commentCount}})</text>
      </view>
      <view class="comments-list">
        <view class="comment-item" wx:for="{{currentComments}}" wx:key="id">
          <text class="comment-user">{{item.user}}</text>
          <text class="comment-text">{{item.content}}</text>
          <text class="comment-time">{{item.time}}</text>
        </view>
        <view class="empty-comments" wx:if="{{commentCount === 0}}">
          <text>暂无评论，快来抢沙发~</text>
        </view>
      </view>
      <view class="comment-input-area">
        <input class="comment-input" placeholder="写下你的想法..." 
               value="{{commentInput}}" bindinput="onCommentInput" bindconfirm="submitComment"/>
        <button class="comment-submit" bindtap="submitComment">发送</button>
      </view>
    </view>
  </view>

  <!-- 隐藏的 Canvas 用于生成分享卡片 -->
  <canvas canvas-id="shareCanvas" style="width:{{canvasWidth}}px;height:{{canvasHeight}}px;position:fixed;left:-9999px;top:-9999px;"></canvas>

</view>
