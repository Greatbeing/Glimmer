.container {
  padding: 16px;
  padding-bottom: 80px;
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #312e81 100%);
  min-height: 100vh;
  position: relative;
}

/* Background Glow */
.container::before {
  content: '';
  position: fixed;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 60%);
  animation: glimmer-rotate 20s linear infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes glimmer-rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 0 12px;
  position: relative;
  z-index: 1;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.logo {
  font-size: 24px;
  font-weight: 700;
  color: #fef3c7;
  letter-spacing: 2px;
}

.slogan {
  font-size: 11px;
  color: #fde68a;
  opacity: 0.7;
  letter-spacing: 3px;
  margin-top: 4px;
}

.header-bulb {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(251, 191, 36, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 2s ease-in-out infinite;
}

.header-bulb-icon {
  font-size: 16px;
  color: #fcd34d;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.05); }
}

/* Quote Card */
.quote-card {
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  overflow: hidden;
  position: relative;
  z-index: 1;
  box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
}

.quote-card::before {
  content: '';
  position: absolute;
  top: -40px;
  right: -40px;
  width: 128px;
  height: 128px;
  background: rgba(245, 158, 11, 0.2);
  border-radius: 50%;
  filter: blur(64px);
  pointer-events: none;
}

.quote-inner {
  padding: 24px;
  position: relative;
  z-index: 1;
}

.quote-badge {
  display: inline-flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.2);
  padding: 4px 12px;
  border-radius: 999px;
  border: 1rpx solid rgba(255,255,255,0.05);
  margin-bottom: 16px;
}

.badge-icon {
  font-size: 14px;
  margin-right: 6px;
}

.badge-text {
  font-size: 12px;
  color: #d1d5db;
}

/* Wave Animation */
.wave {
  display: flex;
  align-items: flex-end;
  height: 12px;
  margin-left: 4px;
  gap: 2px;
}

.wave-bar {
  width: 2px;
  background: rgba(255,255,255,0.5);
  border-radius: 1px;
  animation: wave-bounce 1s ease-in-out infinite;
}

.wave-bar:nth-child(1) { height: 8px; animation-delay: 0s; }
.wave-bar:nth-child(2) { height: 12px; animation-delay: 0.2s; }
.wave-bar:nth-child(3) { height: 4px; animation-delay: 0.4s; }

@keyframes wave-bounce {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(0.5); }
}

.quote-zh {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 20px;
  line-height: 1.8;
  color: #fffbf7;
  font-weight: 500;
  margin-bottom: 16px;
}

.quote-en {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 14px;
  font-style: italic;
  color: #9ca3af;
  border-left: 4rpx solid rgba(245, 158, 11, 0.3);
  padding-left: 12px;
  margin-bottom: 16px;
}

.quote-source {
  font-size: 14px;
  color: #fde68a;
  opacity: 0.8;
  font-weight: 600;
}

.quote-context {
  font-size: 12px;
  color: #9ca3af;
  line-height: 1.6;
  margin-top: 8px;
}

.quote-tag {
  display: inline-block;
  padding: 2px 8px;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.2);
  border-radius: 4px;
  font-size: 12px;
  color: #fde68a;
  margin-top: 12px;
}

.quote-tag-cat {
  opacity: 0.5;
  margin-left: 4px;
}

/* Quote Actions */
.quote-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24px;
  padding-top: 16px;
  border-top: 1rpx solid rgba(255,255,255,0.1);
}

.actions-left {
  display: flex;
  gap: 16px;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #d1d5db;
}

.action-btn.liked { color: #f87171; }
.action-btn.caught { color: #fcd34d; }

.action-icon { font-size: 20px; }
.action-count { font-size: 13px; }

.capture-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(245, 158, 11, 0.2);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  padding: 6px 12px;
  border-radius: 999px;
  color: #fcd34d;
  font-size: 13px;
}

.capture-icon { font-size: 16px; }

/* Dots */
.quote-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 24px;
  position: relative;
  z-index: 1;
}

.dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: all 0.3s ease;
}

.dot.active {
  background: #fbbf24;
  width: 24px;
  border-radius: 4px;
}

/* Header Right */
.header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.settings-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

/* Loading Overlay */
.quote-card.loading {
  pointer-events: none;
}

.loading-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15,23,42,0.85);
  backdrop-filter: blur(8px);
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.loading-spinner {
  width: 28px;
  height: 28px;
  border: 3px solid rgba(255,255,255,0.15);
  border-top-color: #fbbf24;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 12px;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: rgba(255,255,255,0.7);
  font-size: 14px;
  font-family: serif;
}
